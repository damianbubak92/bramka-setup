<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/blue_700"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Rule Name -->
        <TextView
            android:id="@+id/textRuleName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rule Name"
            android:textStyle="bold"
            android:textSize="16sp"
            android:fontFamily="@font/roboto" />

        <!-- Edit button -->
        <ImageButton
            android:id="@+id/btnEditRule"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="8dp"
            android:backgroundTint="@null"
            android:src="@drawable/ic_edit"
            android:contentDescription="Edit Rule" />

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/btnDeleteRule"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_toStartOf="@id/btnEditRule"
            android:backgroundTint="@null"
            android:src="@drawable/ic_delete"
            android:contentDescription="Delete Rule" />

        <!-- Conditions summary -->
        <TextView
            android:id="@+id/textRuleConditions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/textRuleName"
            android:layout_marginTop="4dp"
            android:text="09:00-17:00; T1 > 50;"
            android:textSize="14sp"
            android:fontFamily="@font/roboto" />

        <!-- Action summary -->
        <TextView
            android:id="@+id/textRuleAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/textRuleConditions"
            android:layout_marginTop="4dp"
            android:text="SetRelay: On"
            android:textSize="14sp"
            android:fontFamily="@font/roboto" />

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
