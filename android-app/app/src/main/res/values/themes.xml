<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.GatewayCommunicator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/blue_700</item>
        <item name="colorPrimaryDark">@color/blue_700</item>
        <item name="colorAccent">@color/blue_700</item>
        <item name="android:fontFamily">@font/roboto</item>
    </style>
    <style name="ToolbarTitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:fontFamily">@font/roboto</item>
        <item name="android:textSize">24sp</item> <!-- lub np. 18sp -->
        <item name="android:textColor">@android:color/white</item>
    </style>
    <!-- wymusza spinner zamiast tarczy -->
    <style name="TimePickerSpinnerTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:timePickerStyle">@style/SpinnerTimePicker</item>
    </style>

    <style name="SpinnerTimePicker" parent="@android:style/Widget.Material.TimePicker">
        <item name="android:timePickerMode">spinner</item>
    </style>
    <!-- Overlay dla MaterialTimePicker -->
    <style name="ThemeOverlay.GatewayCommunicator.TimePicker" parent="ThemeOverlay.MaterialComponents.TimePicker">
        <!-- Kolory nagłówka / tytułu
        <item name="materialTimePicker">@color/white</item>
        <item name="materialTimePickerHeaderTextColor">@color/white</item>

        <item name="materialTimePickerClockFaceBackgroundColor">@color/blue_700</item>
        <item name="materialTimePickerClockHandColor">@color/white</item>
        <item name="materialTimePickerClockNumberTextColor">@color/white</item>
        <item name="materialTimePickerSelectorColor">@color/blue_700</item>  -->
    </style>
</resources>